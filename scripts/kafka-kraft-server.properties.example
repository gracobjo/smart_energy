# Copiar a $KAFKA_HOME/config/kraft/server.properties si el broker no arranca o da timeout en topics.
# Tras cambiar, si hace falta re-formatear: parar Kafka, vaciar log.dirs y ejecutar kafka-storage format.

process.roles=broker,controller
node.id=1
controller.quorum.voters=1@127.0.0.1:9093
controller.listener.names=CONTROLLER

# Kafka 3.9+: advertised.listeners NO puede ser 0.0.0.0 (usa 127.0.0.1 o la IP del nodo).
# Desde otra máquina: listeners=PLAINTEXT://0.0.0.0:9092 y advertised=PLAINTEXT://IP_REAL:9092
listeners=PLAINTEXT://127.0.0.1:9092,CONTROLLER://127.0.0.1:9093
advertised.listeners=PLAINTEXT://127.0.0.1:9092
listener.security.protocol.map=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
inter.broker.listener.name=PLAINTEXT

log.dirs=/CAMBIAR/ruta/a/kafka/logs

offsets.topic.replication.factor=1
transaction.state.log.replication.factor=1
transaction.state.log.min.isr=1
group.initial.rebalance.delay.ms=0
