# Copiar a .env o exportar en el shell (no commitear .env)
OPENWEATHER_API_KEY=
API_WEATHER_KEY=
ELECTRICITY_MAPS_API_KEY=
ELECTRICITY_MAPS_ZONE=ES

# NiFi (opcional)
NIFI_HOME=~/smart_energy/nifi-2.6.0
# Credenciales API NiFi (single-user; ver logs/nifi-app.log "Generated Username/Password")
NIFI_USER=
NIFI_PASS=

# Airflow UI (opcional)
# Usuario por defecto: admin. Contraseña inicial en ~/airflow/simple_auth_manager_passwords.json.generated
AIRFLOW_USER=admin
AIRFLOW_PASS=
